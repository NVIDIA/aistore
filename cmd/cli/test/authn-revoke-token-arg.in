// RUN authn
echo "/tmp/auth-token.$RANDOM.adm1" > /tmp/e2e.admin1.rand
admin_token_file_1=`cat /tmp/e2e.admin1.rand`; ais auth login admin -p admin -f $admin_token_file_1 // IGNORE

# Revoke via --file flag
AIS_AUTHN_TOKEN_FILE=`cat /tmp/e2e.admin1.rand` ais auth rm token -y --file `cat /tmp/e2e.admin1.rand` // IGNORE
AIS_AUTHN_TOKEN_FILE=`cat /tmp/e2e.admin1.rand` ais show cluster // FAIL "revoked"

# Revoke via literal TOKEN and verify the printed token info
echo "/tmp/auth-token.$RANDOM.adm2" > /tmp/e2e.admin2.rand
admin_token_file_2=`cat /tmp/e2e.admin2.rand`; ais auth login admin -p admin -f $admin_token_file_2 // IGNORE
tok2=`grep -o '"token":"[^"]*"' \`cat /tmp/e2e.admin2.rand\` | cut -d'"' -f4`; echo y | AIS_AUTHN_TOKEN_FILE=`cat /tmp/e2e.admin2.rand` ais auth rm token "$tok2" 2>&1 | grep -E "Token to revoke|User:|Admin:|Source:"
AIS_AUTHN_TOKEN_FILE=`cat /tmp/e2e.admin2.rand` ais show cluster // FAIL "revoked"

# Reject a token whose claims cannot be decoded (even with -y)
ais auth rm token "not-a-jwt" -y // FAIL "cannot decode claims"

# Revoke with no TOKEN arg, token taken from AIS_AUTHN_TOKEN_FILE
echo "/tmp/auth-token.$RANDOM.adm3" > /tmp/e2e.admin3.rand
admin_token_file_3=`cat /tmp/e2e.admin3.rand`; ais auth login admin -p admin -f $admin_token_file_3 // IGNORE
AIS_AUTHN_TOKEN_FILE=`cat /tmp/e2e.admin3.rand` ais auth rm token -y // IGNORE
AIS_AUTHN_TOKEN_FILE=`cat /tmp/e2e.admin3.rand` ais show cluster // FAIL "revoked"

# Revoke with no TOKEN arg, token taken from the default token file
ais auth login "$AIS_AUTHN_USERNAME" -p "$AIS_AUTHN_PASSWORD" // IGNORE
env -u AIS_AUTHN_TOKEN_FILE ais auth rm token -y // IGNORE
env -u AIS_AUTHN_TOKEN_FILE ais show cluster // FAIL "revoked"

rm -f `cat /tmp/e2e.admin1.rand` `cat /tmp/e2e.admin2.rand` `cat /tmp/e2e.admin3.rand` /tmp/e2e.admin1.rand /tmp/e2e.admin2.rand /tmp/e2e.admin3.rand // IGNORE
rm -f "$HOME/.config/ais/cli/auth.token" // IGNORE
