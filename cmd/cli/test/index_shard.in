# Test shard-index build and summary commands

# Create bucket
ais bucket create ais://$BUCKET // IGNORE

# Generate 5 TAR shards (2 files each) under the tested prefix
ais archive gen-shards "ais://$BUCKET/shards/shard-{001..005}.tar" --fcount 2 // IGNORE

# Generate one TAR shard outside the tested prefix
ais archive gen-shards "ais://$BUCKET/skip/shard-{001..001}.tar" --fcount 2 // IGNORE

# Add a non-TAR object (must be skipped, not indexed)
head -c 1024 /dev/urandom | ais object put - ais://$BUCKET/readme.md // IGNORE

# Reject invalid job IDs instead of starting a new summary job
ais bucket shard-index summary ais://$BUCKET bad-id --dont-wait // FAIL "invalid job ID"
ais bucket shard-index summary ais://$BUCKET abcDEF123 // FAIL "JOB_ID requires --dont-wait"

# Before indexing, the prefix summary must find TAR objects but no indexed shards
ais bucket shard-index summary ais://$BUCKET/shards/ --no-headers | awk '{print "pre-summary=" $2 "," $4 "," $6 "," $7}'

# Run shard-index build and wait for completion
ais bucket shard-index build ais://$BUCKET/shards/ --wait // IGNORE

# Extract processed-object count from the job summary;
# 5 TAR shards under shards/ were indexed, skip/ and readme.md were not selected --> expect indexed=5
# Sum the OBJECTS column across all target rows.
ais show job index-shard ais://$BUCKET --all --no-headers 2>&1 | awk '$3 == "index-shard" {sum += $5} END {print "indexed=" sum}'

# After indexing, prefix summary must count only shards/ TAR objects
ais bucket shard-index summary ais://$BUCKET --prefix shards/ --no-headers | awk '{print "summary=" $2 "," $4 "," $6 "," $7}'

# Start asynchronously and poll by UUID
ais bucket shard-index summary ais://$BUCKET/shards/ --dont-wait | awk -F'[][]' '{print $2}' // SAVE_RESULT
for i in $(seq 1 30); do out=$(ais bucket shard-index summary ais://$BUCKET/shards/ $RESULT --dont-wait --no-headers 2>/dev/null || true); if echo "$out" | grep -q "^ais://"; then echo "$out" | awk '{print "poll-summary=" $2 "," $4 "," $6 "," $7}'; break; fi; sleep 0.1; done

# Clean up
ais bucket rm --yes ais://$BUCKET // IGNORE
